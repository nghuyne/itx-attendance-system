# ============================================================
# ITX Attendance System — Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ============================================================

# ----- Database -----
DB_ROOT_PASSWORD=change_me_root_password
DB_USERNAME=root
DB_PASSWORD=change_me_db_password

# ----- MinIO Object Storage -----
MINIO_ACCESS_KEY=change_me_minio_user
MINIO_SECRET_KEY=change_me_minio_password

# ----- JWT (minimum 32 characters, randomly generated) -----
JWT_SECRET=change_me_jwt_secret_minimum_32_characters_long

# ----- CORS (comma-separated list of allowed frontend origins) -----
# Development: http://localhost:5173
# Production:  https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Mail (optional) -----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@itx.local
